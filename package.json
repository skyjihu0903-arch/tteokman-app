## 11) `app/products/[slug]/page.tsx`

```tsx
import Link from 'next/link';
import { notFound } from 'next/navigation';

const products = [
  {
    slug: 'signature-milteokbokki',
    title: '시그니처 밀떡볶이',
    category: '떡볶이',
    price: 89000,
    salePrice: 69000,
    difficulty: '초중급',
    target: '배달/매장 창업 입문자',
    description: '검증된 판매 데이터를 기반으로 정리된 떡볶이 창업용 레시피입니다. 소스 배합표, 제조 순서, 실패 포인트, 배달 최적화 팁이 포함됩니다.'
  },
  {
    slug: 'premium-fire-tteokbokki',
    title: '불향 프리미엄 떡볶이',
    category: '프리미엄',
    price: 149000,
    salePrice: 119000,
    difficulty: '중급',
    target: '객단가 높은 배달 매장',
    description: '불향 오일과 응용 토핑 전략이 포함된 프리미엄 레시피입니다.'
  }
];

function formatPrice(value: number) {
  return new Intl.NumberFormat('ko-KR').format(value) + '원';
}

export default function ProductDetailPage({ params }: { params: { slug: string } }) {
  const product = products.find((item) => item.slug === params.slug);
  if (!product) return notFound();

  return (
    <section className="grid gap-6 md:grid-cols-[1.1fr_0.9fr]">
      <div className="rounded-3xl bg-white p-8 shadow-sm">
        <p className="text-sm text-gray-500">{product.category}</p>
        <h1 className="mt-2 text-3xl font-bold">{product.title}</h1>
        <p className="mt-4 leading-7 text-gray-600">{product.description}</p>

        <div className="mt-6 space-y-2 text-sm text-gray-600">
          <p>난이도: {product.difficulty}</p>
          <p>추천 타겟: {product.target}</p>
        </div>

        <div className="mt-6 flex items-center gap-3">
          <span className="text-2xl font-bold">{formatPrice(product.salePrice)}</span>
          <span className="text-sm text-gray-400 line-through">{formatPrice(product.price)}</span>
        </div>
      </div>

      <div className="rounded-3xl bg-white p-8 shadow-sm">
        <h2 className="text-xl font-bold">구매 전 동의</h2>
        <div className="mt-4 rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900">
          본 자료는 구매자 본인만 사용할 수 있으며 재배포, 재판매, 제3자 공유가 금지됩니다.
        </div>

        <form className="mt-6 space-y-4">
          <div>
            <label className="mb-2 block text-sm font-medium">이름</label>
            <input className="w-full rounded-2xl border px-4 py-3" placeholder="홍길동" />
          </div>
          <div>
            <label className="mb-2 block text-sm font-medium">이메일</label>
            <input type="email" className="w-full rounded-2xl border px-4 py-3" placeholder="email@example.com" />
          </div>
          <label className="flex items-start gap-3 rounded-2xl border p-4 text-sm">
            <input type="checkbox" className="mt-1" />
            <span>재배포·재판매 금지 및 라이선스 정책에 동의합니다.</span>
          </label>
          <Link href="/checkout" className="block rounded-2xl bg-black px-5 py-3 text-center text-white">
            계약 동의 후 구매 진행
          </Link>
        </form>
      </div>
    </section>
  );
}
```

