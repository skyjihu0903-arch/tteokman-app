## 10) `app/products/page.tsx`

```tsx
import Link from 'next/link';

const products = [
  {
    id: 1,
    slug: 'signature-milteokbokki',
    title: '시그니처 밀떡볶이',
    category: '떡볶이',
    price: 89000,
    salePrice: 69000,
    description: '대중성 높은 단짠매 밸런스와 재현성을 갖춘 창업용 레시피'
  },
  {
    id: 2,
    slug: 'premium-fire-tteokbokki',
    title: '불향 프리미엄 떡볶이',
    category: '프리미엄',
    price: 149000,
    salePrice: 119000,
    description: '불향 오일 응용 구조까지 포함한 객단가 상승형 레시피'
  }
];

function formatPrice(value: number) {
  return new Intl.NumberFormat('ko-KR').format(value) + '원';
}

export default function ProductsPage() {
  return (
    <section>
      <div className="mb-6">
        <h1 className="text-3xl font-bold">레시피 상품</h1>
        <p className="mt-2 text-gray-600">창업용 떡볶이 레시피와 운영 자료</p>
      </div>

      <div className="grid gap-6 md:grid-cols-2">
        {products.map((product) => (
          <Link key={product.id} href={`/products/${product.slug}`} className="rounded-3xl bg-white p-6 shadow-sm transition hover:-translate-y-1">
            <p className="text-sm text-gray-500">{product.category}</p>
            <h2 className="mt-2 text-2xl font-bold">{product.title}</h2>
            <p className="mt-3 text-gray-600">{product.description}</p>
            <div className="mt-5 flex items-center gap-3">
              <span className="text-xl font-bold">{formatPrice(product.salePrice)}</span>
              <span className="text-sm text-gray-400 line-through">{formatPrice(product.price)}</span>
            </div>
          </Link>
        ))}
      </div>
    </section>
  );
}
```

